  "corePackage": {
    "name": "martenweave-core",
    "version": "0.4.1",
    "pythonModule": "modelops_core",
    "primaryCli": "martenweave",
    "compatibilityCli": "modelops",
    "programmingLanguage": "Python",
    "runtimePlatform": "Python 3.11+"
  },
  "sourceOfTruth": {
    "format": "Markdown and YAML canonical model files",
    "canonicalFilesAreAuthoritative": true,
    "generatedIndexesAreDerived": true,
    "generatedArtifacts": [
      "SQLite index",
      "search JSONL",
      "lineage JSONL",
      "reports",
      "review exports"
    ]
  },
  "capabilities": [
    "canonical model files",
    "deterministic data model validation",
    "generated SQLite and JSONL indexes",
    "search and structured query",
    "trace and impact analysis",
    "dataset profiling",
    "dataset gap detection",
    "lineage for migration",
    "health and governance reports",
    "CSV and XLSX model review workflows",
    "JSON Schema export",
    "AI PatchProposal workflow",
    "PatchProposal to ChangeRequest lifecycle",
    "human approval gates",
    "local API and MCP integration surfaces"
  ],
  "audiences": [
    "SAP migration teams",
    "MDM teams",
    "data governance teams",
    "data quality teams",
    "AMS and support teams",
    "data architects",
    "data stewards",
    "technical evaluators"
  ],
  "useCases": [
    "SAP migration model registry",
    "SAP MDM data governance",
    "Business Partner model governance",
    "Customer and Vendor data migration",
    "field mapping validation",
    "migration data quality",
    "dataset gap detection",
    "lineage and impact analysis",
    "AMS knowledge reuse",
    "human-approved AI patch proposals"
  ],
  "aiPolicy": {
    "summary": "AI proposes. Validators verify. Humans approve.",
    "silentCanonicalMutationAllowed": false,
    "deterministicValidationRequired": true,
    "humanApprovalRequired": true
  },
  "integrationBoundaries": {
    "localFirst": true,
    "directSapWriteBack": false,
    "autonomousMdmSynchronization": false,
    "hostedUserInterfaceInCore": false
  },
